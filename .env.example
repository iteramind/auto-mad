# PostgreSQL connection string. En Railway lo inyecta el plugin de Postgres
# (usa la referencia ${{ Postgres.DATABASE_URL }} en las variables del servicio).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/automad?schema=public"

# Correo del panel admin (el respondiente NO usa login).
ADMIN_EMAIL="admin@sesfi.org"

# Contraseña del admin. Elige UNA de las dos opciones:
#
# Opción A (recomendada para Railway): contraseña en texto plano.
#   En el dashboard de Railway las variables se guardan literales, sin conflicto.
ADMIN_PASSWORD="cambia-esta-contrasena"
#
# Opción B: hash bcrypt (más seguro si el .env pudiera filtrarse). Generar con:
#   node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 10))" 'TU_CONTRASEÑA'
#   OJO: si usas un archivo .env LOCAL, escapa cada '$' del hash como '\$'
#   (Railway no necesita el escape). Si defines ADMIN_PASSWORD_HASH, tiene prioridad.
# ADMIN_PASSWORD_HASH=""

# Secreto para firmar la cookie de sesión (mínimo 32 caracteres).
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""
